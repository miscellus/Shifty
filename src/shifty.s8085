; 	  lhld PlayerDeltaPos ; [HL] = delta
; 	  ; [DE] = box pos
; 	  mov a, d
; 	  add h
; 	  mov d, a
; 	  mov a, e
; 	  add l
; 	  mov e, a

; 	  ; For now, just push a single box at a time
; 	  lxi h, Level.TileData
; 	  ; [DE] = probe pos
; 	  call GetByteAtPos
; 	  mov c, a ; [C] = probed tile
; 	  rlc
; 	  jc .retCf
; 	  rlc
; 	  jc .retCf
; 	; The tile was not empty, so return with CF to cancel move

; .canMove:
; 	; Ok the tile after the box was empty, move the box

; 	;
; 	; Set probe pos to box tile
; 	;
; 	; [HL] = box pos
; 	; [DE] = probe pos
; 	; [B] = box tile
; 	lxi h, Level.TileData
; 	call SetByteAtPos ; TODO: can we use the index versions to avoid recomputing the index

; 	; Draw the new box location
; 	di
; 	lxi h, TileCrateStone ; @hardcode this should be dynamic based on what tile we just pushed.
; 	; [DE] = probe pos
; 	; [HL] = ptr to box tile bitmap
