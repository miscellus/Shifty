TileIndexMask       equ 0b00011111
GroundTileIndexMask equ 0b00000011

TargetNec equ 1
; TargetT100 equ 1
	include "hardware.s8085"

	org MapRamBase
GameStart:
	call GameInit
GameLoop:
	call CheckStopKey
	rc

	call ReadInput
	jz GameLoop ; If none of the movement keys were pressed, jump back

	call PlayerMove
	jc GameLoop

	call Draw
	jmp GameLoop

PlayerMove:
; [B] = pressed key state
; Output:
;  CF = 1 if move was cancelled, 0 otherwise
; Clobbers: assume all

	xra a
	mov d, a ; zero [DE]
	mov e, a

	mov a, b ; restore pressed
	ani KeyLeft
	jz .leftNotPressed
	dcr d
.leftNotPressed:

	mov a, b ; restore pressed
	ani KeyRight
	jz .rightNotPressed
	inr d
.rightNotPressed:

	mov a, d
	ora a
	jnz .skipVertical

	mov a, b ; restore pressed
	ani KeyUp
	jz .upNotPressed
	dcr e
.upNotPressed:

	mov a, b ; restore pressed
	ani KeyDown
	jz .downNotPressed
	inr e
.downNotPressed:

.skipVertical:

	xchg
	shld PlayerDeltaPos
	xchg

	; [DE] = relative movement

	lhld PlayerPos
	mov a, d
	add h
	mov h, a
	mov a, e
	add l
	mov l, a
	xchg ; [D] = x, [E] = y

	; [DE] = new pos

	; Check map boundary
	call IsPosOutOfBounds
	rc ; return with carry if the move should be cancelled

	call TileDataFromPos
	; [B] = Tile index
	; [C] = Tile attrib
	mov a, c

	; Check for solid
	rlc ; [CF] = 1 means solid [CF] = 0 means not solid
	rc ; return with carry if the move should be cancelled

	; Check for pushables
	rlc ; [CF] = 1 means pushable [CF] = 0 means not pushable
	rc ; REMOVE REMOVE REMOVE (just placeholder) - makes pushables solid
	; cc MoveBoxes

	push d ; save new player pos
	di
	lhld PlayerPos
	xchg
	lxi h, TileEmpty
	call DrawTile
	ei
	pop h ; restore new player pos in HL
	shld PlayerPos ; Save position that was previously in [DE]

	ora a ; clear carry to indicate that the move was performed
	ret


; MoveBoxes:
; ; [D] = box x
; ; [E] = box y
; ; [B] = box tile data
; 	push b
; 	push d
; 	push h

; 	; probe pos = box pos + delta
